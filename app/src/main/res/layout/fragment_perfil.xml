<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Tarjeta de info del usuario -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <!-- Avatar -->
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>

                <TextView
                    android:id="@+id/tvEmailUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tarjeta de transporte -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modo de transporte preferido"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="16dp"/>

                <RadioGroup
                    android:id="@+id/radioGroupTransporte"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radioPie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚶 A pie"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:tag="pie"/>

                    <RadioButton
                        android:id="@+id/radioBici"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚲 En bicicleta"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:tag="bici"/>

                    <RadioButton
                        android:id="@+id/radioBus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚌 En autobús"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:tag="bus"/>

                    <RadioButton
                        android:id="@+id/radioTranvia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚋 En tranvía"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:tag="tranvia"/>

                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardarTransporte"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Guardar preferencia"
                    android:layout_marginTop="16dp"
                    app:cornerRadius="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tarjeta de idioma -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Idioma de las indicaciones"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="16dp"/>

                <RadioGroup
                    android:id="@+id/radioGroupIdioma"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radioEspanol"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🇪🇸 Español"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:tag="es"/>

                    <RadioButton
                        android:id="@+id/radioEuskera"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏴 Euskera"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:tag="eu"/>

                    <RadioButton
                        android:id="@+id/radioIngles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🇬🇧 English"
                        android:textSize="15sp"
                        android:padding="8dp"
                        android:tag="en"/>

                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardarIdioma"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Guardar idioma"
                    android:layout_marginTop="16dp"
                    app:cornerRadius="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Editar Perfil"
            android:layout_marginTop="16dp"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Botón cerrar sesión -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Cerrar sesión"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>


    </LinearLayout>
</ScrollView>